#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>

void ft_print_comb(){
int *liste = NULL;
int lenghtlist = 1;

int i;
int y;
for(y=0;y<800;y++){
	lenghtlist++;
	liste = realloc(liste,lenghtlist * sizeof(int));
	liste[y] = y;
//	printf("%d\n",liste[y]);
}

for(i=0;i<800;i++){
	int A=liste[i]/100; //7
	int b=liste[i]/10 ; //78
	int c=liste[i]; //789
	
	int B = b - A*10;
	int C = c - b*10; 	

	if(A < B && B < C){
	printf("%d%d%d\n",A,B,C);
	}
	else{
	continue;
	}
	
}

}

int main(void){
	ft_print_comb();
	return 0;
	}
